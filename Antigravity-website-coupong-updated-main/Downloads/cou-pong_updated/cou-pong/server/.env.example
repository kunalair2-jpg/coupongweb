# Server Port
PORT=5000

# Gmail SMTP Configuration
# 1. Use your Gmail address.
# 2. For Password, you MUST use an 'App Password' if 2-Step Verification is enabled.
#    - Go to Google Account > Security > App Passwords > Generate new (Select 'Mail' and 'Other')
#    - Or allow access for less secure apps (less recommended).
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
